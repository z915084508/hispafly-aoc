# PostgreSQL connection used by Prisma. Do not commit real credentials.
DATABASE_URL="postgresql://aoc_user:change-me@localhost:5432/hispafly_aoc?schema=public"

# vAMSYS Pilot OAuth (Authorization Code + PKCE; no client secret).
VAMSYS_PILOT_CLIENT_ID=""
VAMSYS_PILOT_REDIRECT_URI="http://localhost:3000/api/vamsys/oauth/callback"
VAMSYS_PILOT_SCOPES="identity:basic identity:networks identity:discord identity:social pilot:read pilot:write flights:read flights:write activities:read activities:write"
VAMSYS_API_BASE_URL="https://vamsys.io/api/v3/pilot"
VAMSYS_AUTH_URL="https://vamsys.io/oauth/authorize"
VAMSYS_TOKEN_URL="https://vamsys.io/oauth/token"

# vAMSYS Operations API (server-to-server Client Credentials; never expose these values in frontend code).
VAMSYS_OPERATIONS_CLIENT_ID=""
VAMSYS_OPERATIONS_CLIENT_SECRET=""
VAMSYS_OPERATIONS_API_BASE_URL="https://vamsys.io/api/v3/operations"
VAMSYS_OPERATIONS_TOKEN_URL="https://vamsys.io/oauth/token"

# Used when authentication is introduced.
AUTH_SECRET="replace-with-a-long-random-value"
CRON_SECRET="replace-with-a-long-random-cron-secret"
AOC_PILOT_SESSION_SECRET="replace-with-a-long-random-pilot-session-secret"
NEXT_PUBLIC_APP_NAME="HISPAFLY AOC"

# Development-only staff identity. Replace this adapter when real staff authentication is introduced.
# Options: admin@hispafly.local, ops@hispafly.local, finance@hispafly.local, viewer@hispafly.local
MOCK_STAFF_EMAIL="admin@hispafly.local"

# Local Admin Portal login. Override these in `.env` before production use.
AOC_ADMIN_USERNAME="Admin"
AOC_ADMIN_PASSWORD="change-me"
AOC_ADMIN_SESSION_SECRET="change-me-long-random-session-secret"
AOC_ADMIN_STAFF_EMAIL="admin@hispafly.local"

# Development only. Leave disabled when using real Operations API data.
ALLOW_MOCK_SEED="false"
