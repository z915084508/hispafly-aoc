# PostgreSQL connection used by Prisma. Do not commit real credentials.
DATABASE_URL="postgresql://aoc_user:change-me@localhost:5432/hispafly_aoc?schema=public"

# DEPRECATED / LEGACY ONLY. TASK 4.7 blocks all vAMSYS production requests.
# Retain deployed values until TASK 5 replacement and final secret-removal approval.
# These variables must not be used to reconnect automatically.
# vAMSYS Pilot OAuth (historical configuration).
VAMSYS_PILOT_CLIENT_ID=""
VAMSYS_PILOT_REDIRECT_URI="http://localhost:3000/api/vamsys/oauth/callback"
VAMSYS_PILOT_SCOPES="identity:basic identity:networks identity:discord identity:social pilot:read pilot:write flights:read flights:write activities:read activities:write"
VAMSYS_API_BASE_URL="https://vamsys.io/api/v3/pilot"
VAMSYS_AUTH_URL="https://vamsys.io/oauth/authorize"
VAMSYS_TOKEN_URL="https://vamsys.io/oauth/token"

# Navigraph / SimBrief API V2 (Authorization Code + PKCE; server-side only).
NAVIGRAPH_CLIENT_ID=""
NAVIGRAPH_CLIENT_SECRET=""
NAVIGRAPH_AUTHORIZATION_URL=""
NAVIGRAPH_TOKEN_URL=""
NAVIGRAPH_API_BASE_URL="https://api.simbrief.com/v2"
NAVIGRAPH_REDIRECT_URI="http://localhost:3000/api/auth/navigraph/callback"

# Exact EFB origins allowed to call performance APIs.
EFB_ALLOWED_ORIGINS="https://efb.hispafly.es,https://hispafly-efb.vercel.app,http://localhost:3001,http://localhost:3000"

# DEPRECATED / LEGACY ONLY. vAMSYS Operations access is frozen.
# vAMSYS Operations API (historical configuration; never expose values in frontend code).
VAMSYS_OPERATIONS_CLIENT_ID=""
VAMSYS_OPERATIONS_CLIENT_SECRET=""
VAMSYS_OPERATIONS_API_BASE_URL="https://vamsys.io/api/v3/operations"
VAMSYS_OPERATIONS_TOKEN_URL="https://vamsys.io/oauth/token"
VAMSYS_OPERATIONS_SCOPES="*"
# Recommended after vAMSYS grants these scopes:
# VAMSYS_OPERATIONS_SCOPES="ops:read ops:config:write ops:flights:write"

AUTH_SECRET="replace-with-a-long-random-value"
CRON_SECRET="replace-with-a-long-random-cron-secret"
AOC_PILOT_SESSION_SECRET="replace-with-a-long-random-pilot-session-secret"
NEXT_PUBLIC_APP_NAME="HISPAFLY AOC"

# Development-only Staff identity when DATABASE_URL is unavailable.
MOCK_STAFF_EMAIL="admin@hispafly.local"

# Legacy Staff recovery login. Keep enabled for the first independent-login deployment,
# configure an OWNER personal password, test it, then set this flag to false and redeploy.
AOC_LEGACY_ADMIN_LOGIN_ENABLED="true"
AOC_ADMIN_USERNAME="Admin"
AOC_ADMIN_PASSWORD="change-me"
AOC_ADMIN_SESSION_SECRET="change-me-long-random-session-secret"
AOC_ADMIN_STAFF_EMAIL="admin@hispafly.local"
AOC_OWNER_EMAIL=""

# Development only. Leave disabled when using real Operations API data.
ALLOW_MOCK_SEED="false"
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors
AOC_ADMIN_SESSION_SECRET=
AOC_PILOT_SESSION_SECRET=
# DEPRECATED. Required only to decrypt retained historical OAuth records.
VAMSYS_TOKEN_ENCRYPTION_KEY=
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="hispafly@gmail.com"
SMTP_PASSWORD="replace-with-google-app-password"
AUTH_EMAIL_FROM="HISPAFLY <hispafly@gmail.com>"
APP_BASE_URL="https://aoc.hispafly.es"
