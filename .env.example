# PostgreSQL connection used by Prisma. Do not commit real credentials.
DATABASE_URL="postgresql://aoc_user:change-me@localhost:5432/hispafly_aoc?schema=public"

# Reserved for a future read-only vAMSYS integration. Not used in v0.1.
VAMSYS_API_BASE_URL=""
VAMSYS_API_TOKEN=""

# Used when authentication is introduced.
AUTH_SECRET="replace-with-a-long-random-value"
NEXT_PUBLIC_APP_NAME="HISPAFLY AOC"

# Development-only staff identity. Replace this adapter when real staff authentication is introduced.
# Options: admin@hispafly.local, ops@hispafly.local, finance@hispafly.local, viewer@hispafly.local
MOCK_STAFF_EMAIL="admin@hispafly.local"
