generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  ADMIN   @map("admin")
  OPS     @map("operations")
  FINANCE @map("payroll")
  VIEWER  @map("viewer")
}

enum PermissionEffect {
  ALLOW
  DENY
}

enum AuthUserStatus {
  ACTIVE
  DISABLED
  LOCKED
  PENDING_VERIFICATION
}

enum PilotStatus {
  active
  on_leave
  inactive
}

enum PayrollRecordStatus {
  pending
  approved
  rejected
  paid
}

enum PirepStatus {
  accepted
  rejected
}

enum WalletTransactionType {
  payroll
  bonus
  penalty
  manual_adjustment
}

enum CompanyExpenseType {
  airport_landing
  airport_passenger
  airport_service
  airport_parking
  handling
  cargo_handling
  atc_enroute
  atc_terminal
  MAINTENANCE
  AOG_RECOVERY
  MAINTENANCE_FERRY_SUPPORT
}

enum AircraftOperationalStatus {
  NORMAL
  WATCH
  CAUTION
  MAINT_REQUIRED
  FERRY_ONLY
  IN_MAINTENANCE
  AOG
}

enum AircraftMaintenanceStatus {
  NONE
  REQUIRED
  FERRY_TO_BASE
  WAITING_MAINTENANCE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AircraftMaintenanceType {
  LINE_CHECK
  SCHEDULED_CHECK
  HEAVY_CHECK
  AOG_RECOVERY
}

enum FlightOfferStatus {
  DRAFT
  PUBLISHED
  DISPATCHED
  FLOWN
  EXPIRED
  CANCELLED
}

enum FlightDispatchStatus {
  DISPATCHING
  DISPATCHED
  FLOWN
  REWARDED
  FAILED
  CANCELLED
  EXPIRED
}

enum FlightOfferRewardType {
  FIXED
  PERCENTAGE
}

enum PilotBookingStatus {
  BOOKED
  FLOWN
  CANCELLED
  FAILED
}

enum AircraftLocationStatus {
  AVAILABLE
  RESERVED
  IN_FLIGHT
  MAINTENANCE
  UNKNOWN
}

enum AircraftLocationSource {
  MANUAL
  PIREP
  DISPATCH
  ACARS
  VAMSYS_EXTERNAL
  IMPORTED
}

enum AocDataOrigin {
  HISPAFLY_NATIVE
  VAMSYS_LEGACY
  IMPORTED
  MANUAL
}

enum OfpStatus {
  GENERATED
  AWAITING_SIGNATURE
  SIGNED
  VOIDED
}

enum RouteSyncStatus {
  LOCAL_DRAFT
  PUBLISHING
  SYNCED
  UPDATE_PENDING
  SYNC_ERROR
  MISSING
  ARCHIVED
}

enum RouteOperationalStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  INACTIVE
  HIDDEN
  ARCHIVED
}

enum FleetSyncStatus {
  LOCAL_DRAFT
  PUBLISHING
  SYNCED
  UPDATE_PENDING
  SYNC_ERROR
  MISSING
}

enum AircraftSyncStatus {
  LOCAL_DRAFT
  PUBLISHING
  SYNCED
  UPDATE_PENDING
  SYNC_ERROR
  MISSING
}

enum AirportStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FlightScheduleStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum NativeFlightStatus {
  SCHEDULED
  OPEN
  BOOKED
  DISPATCHED
  BOARDING
  DEPARTED
  AIRBORNE
  LANDED
  COMPLETED
  CANCELLED
  DIVERTED
}

model StaffUser {
  id                  String                    @id @default(cuid())
  name                String                    @map("displayName")
  email               String                    @unique
  role                StaffRole                 @default(OPS)
  active              Boolean                   @default(true) @map("isActive")
  staffCode           String?                   @unique
  department          String?
  jobTitle            String?
  roleTemplateId      String?
  roleTemplate        StaffRoleTemplate?        @relation(fields: [roleTemplateId], references: [id], onDelete: SetNull)
  isSystemOwner       Boolean                   @default(false)
  lastLoginAt         DateTime?
  disabledAt          DateTime?
  permissionOverrides StaffPermissionOverride[] @relation("StaffPermissionOverrides")
  auditLogs           AocAuditLog[]
  flightOffers        FlightOffer[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
}

model StaffRoleTemplate {
  id           String                @id @default(cuid())
  code         String                @unique
  name         String
  description  String?
  systemRole   Boolean               @default(false)
  active       Boolean               @default(true)
  displayOrder Int                   @default(0)
  permissions  StaffRolePermission[]
  users        StaffUser[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model StaffPermissionDefinition {
  id           String                    @id @default(cuid())
  code         String                    @unique
  module       String
  name         String
  description  String?
  dangerous    Boolean                   @default(false)
  displayOrder Int                       @default(0)
  roles        StaffRolePermission[]
  overrides    StaffPermissionOverride[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([module, displayOrder])
}

model StaffRolePermission {
  id           String                    @id @default(cuid())
  roleId       String
  permissionId String
  role         StaffRoleTemplate         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   StaffPermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model StaffPermissionOverride {
  id                String                    @id @default(cuid())
  staffUserId       String
  permissionId      String
  effect            PermissionEffect
  reason            String?
  assignedByStaffId String?
  assignedAt        DateTime                  @default(now())
  staffUser         StaffUser                 @relation("StaffPermissionOverrides", fields: [staffUserId], references: [id], onDelete: Cascade)
  permission        StaffPermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([staffUserId, permissionId])
  @@index([effect])
}

model Pilot {
  id                         String                      @id @default(cuid())
  dataOrigin                 AocDataOrigin               @default(HISPAFLY_NATIVE)
  vamsysPilotId              String?                     @unique
  authUserId                 String?                     @unique
  authUser                   AuthUser?                   @relation(fields: [authUserId], references: [id], onDelete: SetNull)
  vamsysUserId               String?                     @unique
  username                   String?
  firstName                  String?
  lastName                   String?
  callsign                   String?                     @unique
  displayName                String
  email                      String?                     @unique
  vatsimId                   String?
  ivaoId                     String?
  discordId                  String?
  simbriefUserId             String?
  rankName                   String?
  rankAbbreviation           String?
  hubId                      String?
  rank                       String?
  base                       String?
  status                     PilotStatus                 @default(active)
  walletBalanceCents         Int                         @default(0)
  pireps                     Pirep[]
  payrollRecords             PayrollRecord[]
  walletTransactions         WalletTransaction[]
  vamsysOAuthToken           VamsysOAuthToken?
  navigraphOAuthToken        NavigraphOAuthToken?
  lastPirepSyncAt            DateTime?
  lastOperationsSyncAt       DateTime?
  operationsRawData          Json?
  notes                      PilotNote[]
  flightDispatches           FlightDispatch[]
  createdFlightOffers        FlightOffer[]               @relation("PilotCreatedFlightOffers")
  pilotBookings              PilotBooking[]
  efbPerformanceCalculations EfbPerformanceCalculation[]
  efbDepartureReadiness      EfbDepartureReadiness[]
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@index([status])
  @@index([base])
  @@index([dataOrigin])
}

model AuthUser {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  username            String                   @unique
  passwordHash        String?
  displayName         String
  status              AuthUserStatus           @default(PENDING_VERIFICATION)
  emailVerifiedAt     DateTime?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int                      @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  pilot               Pilot?
  roles               AuthUserRole[]
  sessions            AuthSession[]
  resetTokens         PasswordResetToken[]
  verificationTokens  EmailVerificationToken[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status])
}

model AuthRole {
  id          String               @id @default(cuid())
  code        String               @unique
  name        String
  description String?
  systemRole  Boolean              @default(false)
  users       AuthUserRole[]
  permissions AuthRolePermission[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model AuthPermission {
  id          String               @id @default(cuid())
  code        String               @unique
  description String?
  roles       AuthRolePermission[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model AuthUserRole {
  userId     String
  roleId     String
  user       AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       AuthRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model AuthRolePermission {
  roleId       String
  permissionId String
  role         AuthRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   AuthPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AuthSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  ipAddress  String?
  userAgent  String?
  revokedAt  DateTime?
  user       AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PilotNote {
  id              String    @id @default(cuid())
  vamsysNoteId    String    @unique
  pilotId         String
  pilot           Pilot     @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  content         String?
  authorName      String?
  rawData         Json?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  synchronizedAt  DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pilotId, sourceCreatedAt])
}

model OperationsApiState {
  id                    String    @id @default("vamsys")
  status                String    @default("unknown")
  lastCheckedAt         DateTime?
  lastSuccessAt         DateTime?
  lastPirepSyncAt       DateTime?
  lastCronPirepSyncAt   DateTime?
  lastPilotSyncAt       DateTime?
  lastCronPilotSyncAt   DateTime?
  lastAirportSyncAt     DateTime?
  lastRouteSyncAt       DateTime?
  lastRouteSyncStatus   String?
  lastRouteSyncError    String?
  lastRouteSyncImported Int       @default(0)
  lastRouteSyncUpdated  Int       @default(0)
  lastRouteSyncMissing  Int       @default(0)
  lastError             String?
  updatedAt             DateTime  @updatedAt
}

model Fleet {
  id                       String                 @id @default(cuid())
  dataOrigin               AocDataOrigin          @default(HISPAFLY_NATIVE)
  vamsysFleetId            String?                @unique
  name                     String?
  code                     String?
  type                     String?
  maxPassengers            Int?
  maxCargoKg               Int?
  active                   Boolean                @default(true)
  containerUnits           Int?
  hiddenInPhoenix          Boolean                @default(false)
  scoringGroupId           String?
  simbriefAircraftProfiles Json?
  simbriefOverrides        Json?
  parameterIds             Json?
  imageUrl                 String?
  imageAttribution         String?
  imageLinkback            String?
  internalNotes            String?
  syncStatus               FleetSyncStatus        @default(LOCAL_DRAFT)
  sourceUpdatedAt          DateTime?
  lastSeenAt               DateTime?
  lastSyncedAt             DateTime?
  lastPublishedAt          DateTime?
  lastSyncError            String?
  rawData                  Json?
  routeAssignments         RouteFleetAssignment[]
  nativeAircraft           Aircraft[]             @relation("NativeFleetAircraft")
  defaultRoutes            Route[]                @relation("RouteDefaultFleet")
  flightOffers             FlightOffer[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([code])
  @@index([type])
  @@index([syncStatus])
  @@index([hiddenInPhoenix])
  @@index([dataOrigin])
}

model Aircraft {
  id                    String                      @id @default(cuid())
  dataOrigin            AocDataOrigin               @default(HISPAFLY_NATIVE)
  vamsysAircraftId      String?                     @unique
  name                  String?
  registration          String?                     @unique
  aircraftType          String?
  fleetId               String?
  nativeFleetId         String?
  nativeFleet           Fleet?                      @relation("NativeFleetAircraft", fields: [nativeFleetId], references: [id], onDelete: SetNull)
  fleetName             String?
  serialNumber          String?
  currentAirportId      String?
  currentAirport        Airport?                    @relation(fields: [currentAirportId], references: [id], onDelete: SetNull)
  status                String?
  seatCapacity          Int?
  cargoCapacityKg       Int?
  containerUnits        Int?
  selcal                String?
  finNumber             String?
  hexcode               String?
  hiddenInPhoenix       Boolean                     @default(false)
  vamsysInternalRemarks String?
  internalNotes         String?
  simbriefOverrides     Json?
  imageUrl              String?
  imageAttribution      String?
  imageLinkback         String?
  syncStatus            AircraftSyncStatus          @default(LOCAL_DRAFT)
  sourceUpdatedAt       DateTime?
  lastSeenAt            DateTime?
  lastSyncedAt          DateTime?
  lastPublishedAt       DateTime?
  lastSyncError         String?
  mtowKg                Int?
  fuelOnBoardKg         Int?
  fuelReportedAt        DateTime?
  publicVisible         Boolean                     @default(false)
  publicDisplayName     String?
  publicDescription     String?
  publicImageUrl        String?
  publicBaseIcao        String?
  publicStatus          String?
  publicDisplayOrder    Int                         @default(0)
  publicPublishedAt     DateTime?
  rawData               Json?
  performanceProfile    AircraftPerformanceProfile?
  assignedFlights       Flight[]
  nativeBookings        PilotBooking[]
  nativeDispatches      FlightDispatch[]
  flightOffers          FlightOffer[]
  locationSnapshot      AircraftLocationSnapshot?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([registration])
  @@index([aircraftType])
  @@index([fleetId])
  @@index([nativeFleetId])
  @@index([currentAirportId])
  @@index([syncStatus])
  @@index([hiddenInPhoenix])
  @@index([publicVisible, publicDisplayOrder])
  @@index([dataOrigin])
}

model AircraftProfile {
  id              String   @id @default(cuid())
  aircraftType    String   @unique
  seatCapacity    Int?
  cargoCapacityKg Int?
  mtowKg          Int?
  source          String   @default("aoc_fallback")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Airport {
  id                String                     @id @default(cuid())
  icao              String                     @unique
  iata              String?
  name              String?
  city              String?
  country           String?
  region            String?
  timezone          String?
  latitude          Float?
  longitude         Float?
  status            AirportStatus              @default(ACTIVE)
  dataOrigin        AocDataOrigin              @default(HISPAFLY_NATIVE)
  source            String                     @default("hispafly_native")
  legacyVamsysId    String?                    @unique
  rawData           Json?
  archivedAt        DateTime?
  departureRoutes   Route[]                    @relation("RouteDepartureAirport")
  arrivalRoutes     Route[]                    @relation("RouteArrivalAirport")
  currentAircraft   Aircraft[]
  locationSnapshots AircraftLocationSnapshot[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([iata])
  @@index([region])
  @@index([dataOrigin])
  @@index([status])
}

model Route {
  id                       String                    @id @default(cuid())
  dataOrigin               AocDataOrigin             @default(HISPAFLY_NATIVE)
  vamsysRouteId            String?                   @unique
  flightNumber             String?
  callsign                 String?
  name                     String?
  routeCode                String?
  departure                String
  arrival                  String
  departureAirportId       String?
  departureAirport         Airport?                  @relation("RouteDepartureAirport", fields: [departureAirportId], references: [id], onDelete: Restrict)
  arrivalAirportId         String?
  arrivalAirport           Airport?                  @relation("RouteArrivalAirport", fields: [arrivalAirportId], references: [id], onDelete: Restrict)
  defaultFleetId           String?
  defaultFleet             Fleet?                    @relation("RouteDefaultFleet", fields: [defaultFleetId], references: [id], onDelete: SetNull)
  route                    String?
  networkPolicy            String?
  scheduledDurationMinutes Int?
  distanceNm               Int?
  cruiseAltitude           Int?
  costIndex                Int?
  defaultPassengers        Int?
  defaultCargoKg           Int?
  minimumRankId            String?
  hubId                    String?
  operationalStatus        RouteOperationalStatus    @default(DRAFT)
  syncStatus               RouteSyncStatus           @default(LOCAL_DRAFT)
  active                   Boolean                   @default(true)
  effectiveFrom            DateTime?
  effectiveUntil           DateTime?
  internalNotes            String?
  sourceUpdatedAt          DateTime?
  lastSeenAt               DateTime?
  lastSyncedAt             DateTime?
  lastPublishedAt          DateTime?
  lastSyncError            String?
  rawData                  Json?
  archivedAt               DateTime?
  fleetAssignments         RouteFleetAssignment[]
  identityReservation      RouteIdentityReservation?
  schedules                FlightSchedule[]
  flights                  Flight[]
  nativeBookings           PilotBooking[]
  nativeDispatches         FlightDispatch[]
  flightOffers             FlightOffer[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([departure, arrival])
  @@index([departureAirportId, arrivalAirportId])
  @@index([defaultFleetId])
  @@index([routeCode])
  @@index([flightNumber])
  @@index([operationalStatus])
  @@index([syncStatus])
  @@index([active])
  @@index([lastSyncedAt])
  @@index([dataOrigin])
}

model RouteIdentityReservation {
  id           String   @id @default(cuid())
  routeId      String   @unique
  route        Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  flightNumber String   @unique
  callsign     String   @unique
  createdAt    DateTime @default(now())
}

model RouteFleetAssignment {
  id            String   @id @default(cuid())
  routeId       String
  fleetId       String
  vamsysRouteId String?
  vamsysFleetId String?
  route         Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  fleet         Fleet    @relation(fields: [fleetId], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())

  @@unique([routeId, fleetId])
  @@index([vamsysRouteId])
  @@index([vamsysFleetId])
}

model AirportCategoryChargeProfile {
  id                       String   @id @default(cuid())
  airportCategory          String   @unique
  landingRatePerTonneCents Int      @default(0)
  passengerFeeCents        Int      @default(0)
  passengerServiceFeeCents Int      @default(0)
  parkingRatePerHourCents  Int      @default(0)
  terminalAtcUnitRateCents Int      @default(0)
  currency                 String   @default("EUR")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AirportChargeProfile {
  id                       String   @id @default(cuid())
  airportIcao              String   @unique
  airportCategory          String   @default("standard")
  landingRatePerTonneCents Int      @default(0)
  passengerFeeCents        Int      @default(0)
  passengerServiceFeeCents Int      @default(0)
  parkingRatePerHourCents  Int      @default(0)
  terminalAtcUnitRateCents Int      @default(0)
  currency                 String   @default("EUR")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AirspaceChargeProfile {
  id            String   @id @default(cuid())
  region        String   @unique
  unitRateCents Int      @default(0)
  currency      String   @default("EUR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VamsysOAuthToken {
  id           String    @id @default(cuid())
  pilotId      String    @unique
  pilot        Pilot     @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([expiresAt])
  @@index([revokedAt])
}

model Pirep {
  id                     String                @id @default(cuid())
  dataOrigin             AocDataOrigin         @default(HISPAFLY_NATIVE)
  vamsysPirepId          String                @unique
  vamsysBookingId        String?
  pilotId                String
  pilot                  Pilot                 @relation(fields: [pilotId], references: [id], onDelete: Restrict)
  flightNumber           String?
  callsign               String?
  departure              String?
  arrival                String?
  aircraftType           String?
  vamsysAircraftId       String?
  aircraftRegistration   String?
  network                String?
  flightTimeMinutes      Int?
  blockTimeMinutes       Int?
  landingRate            Int?
  score                  Int?
  fuelUsed               Int?
  rampFuelKg             Int?
  takeoffFuelKg          Int?
  landingFuelKg          Int?
  fuelUpliftKg           Int?
  inheritedFuelKg        Int?
  passengers             Int?
  cargoKg                Int?
  luggageKg              Int?
  freightKg              Int?
  flightDistanceNm       Int?
  passengerRevenueCents  Int?
  fuelCostCents          Int?
  fuelPricePerKgCents    Int?
  fuelPriceRegion        String?
  fuelPriceSource        String?
  fuelCalculationDetails Json?
  points                 Float?
  credits                Float?
  status                 PirepStatus
  acarsSoftware          String?
  source                 String                @default("mock")
  flownAt                DateTime?
  acceptedAt             DateTime?
  vamsysCreatedAt        DateTime?
  vamsysUpdatedAt        DateTime?
  rawData                Json?                 @map("sourcePayload")
  synchronizedAt         DateTime              @default(now())
  payrollRecord          PayrollRecord?
  companyExpenses        CompanyExpense[]
  flightDispatch         FlightDispatch?
  pilotBooking           PilotBooking?
  flightAnalysisReport   FlightAnalysisReport?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([pilotId, flownAt])
  @@index([status, flownAt])
  @@index([source, synchronizedAt])
  @@index([vamsysBookingId])
  @@index([flownAt, passengerRevenueCents])
  @@index([flownAt, fuelCostCents])
  @@index([vamsysAircraftId, flownAt])
  @@index([dataOrigin])
}

model NavigraphOAuthToken {
  id              String    @id @default(cuid())
  pilotId         String    @unique
  pilot           Pilot     @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  navigraphUserId String?
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  scopes          String
  revokedAt       DateTime?
  connectedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([expiresAt])
  @@index([revokedAt])
}

model FuelPrice {
  id                 String   @id @default(cuid())
  region             String
  pricePerKgCents    Int
  currency           String   @default("EUR")
  source             String   @default("IATA Jet Fuel Price Monitor")
  sourceUrl          String?
  effectiveFrom      DateTime @default(now())
  manuallyMaintained Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([region, effectiveFrom])
}

model CompanyExpense {
  id                 String             @id @default(cuid())
  pirepId            String?
  pirep              Pirep?             @relation(fields: [pirepId], references: [id], onDelete: Cascade)
  maintenanceOrderId String?            @unique
  type               CompanyExpenseType
  amountCents        Int
  currency           String             @default("EUR")
  source             String             @default("aoc_economy_rules")
  calculationDetails Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([pirepId, type])
  @@index([type])
  @@index([createdAt])
}

model PayrollRecord {
  id                 String              @id @default(cuid())
  pirepId            String              @unique
  pirep              Pirep               @relation(fields: [pirepId], references: [id], onDelete: Restrict)
  pilotId            String
  pilot              Pilot               @relation(fields: [pilotId], references: [id], onDelete: Restrict)
  payrollRuleId      String?
  payrollRule        PayrollRule?        @relation(fields: [payrollRuleId], references: [id], onDelete: SetNull)
  walletTransaction  WalletTransaction?
  basePayCents       Int
  bonusCents         Int                 @default(0)
  penaltyCents       Int                 @default(0)
  amountCents        Int
  currency           String              @default("EUR")
  calculationDetails Json?
  status             PayrollRecordStatus @default(pending)
  settlementMonth    String
  approvedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([pilotId, status])
  @@index([status, settlementMonth])
}

model WalletTransaction {
  id               String                @id @default(cuid())
  pilotId          String
  pilot            Pilot                 @relation(fields: [pilotId], references: [id], onDelete: Restrict)
  payrollRecordId  String?               @unique
  payrollRecord    PayrollRecord?        @relation(fields: [payrollRecordId], references: [id], onDelete: Restrict)
  flightDispatchId String?               @unique
  flightDispatch   FlightDispatch?       @relation(fields: [flightDispatchId], references: [id], onDelete: Restrict)
  type             WalletTransactionType
  amountCents      Int
  currency         String                @default("EUR")
  description      String
  reference        String?
  createdAt        DateTime              @default(now())

  @@index([pilotId, createdAt])
  @@index([type])
}

model AircraftPerformanceProfile {
  id                     String   @id @default(cuid())
  aircraftId             String   @unique
  aircraft               Aircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  operatingEmptyWeightKg Int?
  maxZeroFuelWeightKg    Int?
  maxTakeoffWeightKg     Int?
  maxLandingWeightKg     Int?
  maxFuelKg              Int?
  maxPayloadKg           Int?
  defaultCostIndex       Int?
  fuelBiasPercent        Float    @default(0)
  taxiFuelKg             Int?
  sampleSize             Int      @default(0)
  locked                 Boolean  @default(false)
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AircraftLocationSnapshot {
  id                   String                 @id @default(cuid())
  aircraftId           String?                @unique
  aircraft             Aircraft?              @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  vamsysAircraftId     String                 @unique
  registration         String?
  aircraftType         String?
  currentAirportId     String?
  currentAirport       Airport?               @relation(fields: [currentAirportId], references: [id], onDelete: SetNull)
  currentAirportIcao   String?
  currentAirportIata   String?
  status               AircraftLocationStatus @default(UNKNOWN)
  source               AircraftLocationSource @default(IMPORTED)
  reservedByDispatchId String?
  lastBookingId        String?
  lastPirepId          String?
  lastVamsysPirepId    String?
  lastLatitude         Float?
  lastLongitude        Float?
  lastAltitude         Float?
  lastGroundSpeed      Float?
  lastReportAt         DateTime?
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([currentAirportIcao])
  @@index([currentAirportId])
  @@index([status])
  @@index([source])
  @@index([lastBookingId])
  @@index([lastVamsysPirepId])
}

model FlightSchedule {
  id                      String               @id @default(cuid())
  dataOrigin              AocDataOrigin        @default(HISPAFLY_NATIVE)
  routeId                 String
  route                   Route                @relation(fields: [routeId], references: [id], onDelete: Restrict)
  code                    String
  daysOfWeek              Int[]
  departureTimeMinutesUtc Int
  arrivalTimeMinutesUtc   Int
  effectiveFrom           DateTime
  effectiveUntil          DateTime?
  status                  FlightScheduleStatus @default(DRAFT)
  legacyExternalReference String?
  flights                 Flight[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@unique([routeId, code, effectiveFrom])
  @@index([routeId, status])
  @@index([effectiveFrom, effectiveUntil])
  @@index([dataOrigin])
}

model Flight {
  id                      String             @id @default(cuid())
  dataOrigin              AocDataOrigin      @default(HISPAFLY_NATIVE)
  routeId                 String
  route                   Route              @relation(fields: [routeId], references: [id], onDelete: Restrict)
  scheduleId              String?
  schedule                FlightSchedule?    @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  operatingDate           DateTime           @db.Date
  scheduledDeparture      DateTime
  scheduledArrival        DateTime
  flightNumber            String
  callsign                String
  assignedAircraftId      String?
  assignedAircraft        Aircraft?          @relation(fields: [assignedAircraftId], references: [id], onDelete: SetNull)
  status                  NativeFlightStatus @default(SCHEDULED)
  legacyExternalReference String?
  offers                  FlightOffer[]
  bookings                PilotBooking[]
  dispatches              FlightDispatch[]
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@unique([operatingDate, flightNumber, scheduledDeparture])
  @@index([routeId, operatingDate])
  @@index([scheduleId, operatingDate])
  @@index([assignedAircraftId, scheduledDeparture, scheduledArrival])
  @@index([status, scheduledDeparture])
  @@index([dataOrigin])
}

model FlightOffer {
  id                       String                @id @default(cuid())
  dataOrigin               AocDataOrigin         @default(HISPAFLY_NATIVE)
  title                    String
  offerType                String                @default("STANDARD")
  titleEs                  String?
  titleEn                  String?
  descriptionEs            String?
  descriptionEn            String?
  flightNumber             String?
  callsign                 String?
  departureIcao            String
  arrivalIcao              String
  routeId                  String?
  route                    Route?                @relation(fields: [routeId], references: [id], onDelete: SetNull)
  flightId                 String?
  flight                   Flight?               @relation(fields: [flightId], references: [id], onDelete: SetNull)
  aircraftId               String?
  aircraft                 Aircraft?             @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  fleetId                  String?
  fleet                    Fleet?                @relation(fields: [fleetId], references: [id], onDelete: SetNull)
  vamsysRouteId            String
  vamsysAircraftId         String
  vamsysFleetId            String?
  availableFrom            DateTime
  scheduledDeparture       DateTime?
  scheduledArrival         DateTime?
  estimatedDurationMinutes Int
  aircraftType             String?
  aircraftRegistration     String?
  passengers               Int?
  cargoKg                  Int?
  loadFactorPercent        Float?
  luggageKg                Int?
  freightKg                Int?                  @default(0)
  baggageKgPerPassenger    Float?
  altitude                 Int?
  network                  String?
  userRoute                String?
  rewardCents              Int                   @default(0)
  rewardType               FlightOfferRewardType @default(FIXED)
  validUntil               DateTime
  status                   FlightOfferStatus     @default(DRAFT)
  createdByStaffId         String?
  createdByStaff           StaffUser?            @relation(fields: [createdByStaffId], references: [id], onDelete: Restrict)
  createdByPilotId         String?
  createdByPilot           Pilot?                @relation("PilotCreatedFlightOffers", fields: [createdByPilotId], references: [id], onDelete: Restrict)
  dispatches               FlightDispatch[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([status, validUntil])
  @@index([availableFrom, validUntil])
  @@index([createdByPilotId, createdAt])
  @@index([routeId])
  @@index([flightId])
  @@index([aircraftId])
  @@index([dataOrigin])
}

model AircraftConditionSnapshot {
  id                           String                    @id @default(cuid())
  vamsysAircraftId             String                    @unique
  registration                 String?
  aircraftType                 String?
  conditionPercent             Decimal                   @default(100) @db.Decimal(5, 2)
  operationalStatus            AircraftOperationalStatus @default(NORMAL)
  maintenanceStatus            AircraftMaintenanceStatus @default(NONE)
  maintenanceBaseIcao          String                    @default("LEVC")
  cyclesSinceMaintenance       Int                       @default(0)
  blockMinutesSinceMaintenance Int                       @default(0)
  lastWearPirepId              String?
  lastVamsysPirepId            String?
  lastMaintenanceAt            DateTime?
  notes                        String?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
}

model AircraftWearEvent {
  id                String   @id @default(cuid())
  vamsysAircraftId  String
  localPirepId      String   @unique
  vamsysPirepId     String?
  previousCondition Decimal  @db.Decimal(5, 2)
  wearPercent       Decimal  @db.Decimal(5, 2)
  newCondition      Decimal  @db.Decimal(5, 2)
  blockMinutes      Int?
  landingRate       Int?
  landingG          Decimal? @db.Decimal(4, 2)
  aircraftType      String?
  factors           Json
  createdAt         DateTime @default(now())

  @@index([vamsysAircraftId, createdAt])
}

model AircraftMaintenanceOrder {
  id                  String                    @id @default(cuid())
  vamsysAircraftId    String
  registration        String?
  aircraftType        String?
  type                AircraftMaintenanceType
  status              AircraftMaintenanceStatus
  currentCondition    Decimal                   @db.Decimal(5, 2)
  targetCondition     Decimal                   @db.Decimal(5, 2)
  estimatedCostCents  Int
  actualCostCents     Int?
  maintenanceBaseIcao String                    @default("LEVC")
  currentAirportIcao  String?
  ferryOfferId        String?
  ferryDispatchId     String?
  startedAt           DateTime?
  completedAt         DateTime?
  notes               String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([vamsysAircraftId, status])
}

model AircraftMaintenanceRule {
  id                          String   @id @default(cuid())
  aircraftCategory            String   @unique
  cycleWearPercent            Decimal  @db.Decimal(5, 2)
  hourlyWearPercent           Decimal  @db.Decimal(5, 2)
  baseInspectionCostCents     Int
  costPerConditionPointCents  Int
  hangarDailyCostCents        Int
  targetConditionPercent      Decimal  @default(90) @db.Decimal(5, 2)
  heavyTargetConditionPercent Decimal  @default(95) @db.Decimal(5, 2)
  mandatoryThresholdPercent   Decimal  @default(30) @db.Decimal(5, 2)
  aogThresholdPercent         Decimal  @default(20) @db.Decimal(5, 2)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model FlightDispatch {
  id                      String               @id @default(cuid())
  dataOrigin              AocDataOrigin        @default(HISPAFLY_NATIVE)
  flightOfferId           String
  flightOffer             FlightOffer          @relation(fields: [flightOfferId], references: [id], onDelete: Restrict)
  pilotId                 String
  pilot                   Pilot                @relation(fields: [pilotId], references: [id], onDelete: Restrict)
  bookingId               String?              @unique
  booking                 PilotBooking?        @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  flightId                String?
  flight                  Flight?              @relation(fields: [flightId], references: [id], onDelete: Restrict)
  routeId                 String?
  route                   Route?               @relation(fields: [routeId], references: [id], onDelete: Restrict)
  aircraftId              String?
  aircraft                Aircraft?            @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  acarsSessionId          String?
  status                  FlightDispatchStatus @default(DISPATCHED)
  vamsysBookingId         String?              @unique
  vamsysPirepId           String?
  matchedPirepId          String?              @unique
  matchedPirep            Pirep?               @relation(fields: [matchedPirepId], references: [id], onDelete: Restrict)
  rewardWalletTransaction WalletTransaction?
  dispatchedAt            DateTime?
  selectedDepartureAt     DateTime?
  estimatedArrivalAt      DateTime?
  completedAt             DateTime?
  rewardedAt              DateTime?
  cancelledAt             DateTime?
  errorMessage            String?
  ofpBriefing             OfpBriefing?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([pilotId, status])
  @@index([flightOfferId, status])
  @@index([flightId, status])
  @@index([routeId])
  @@index([aircraftId, status])
  @@index([dataOrigin])
}

model OfpBriefing {
  id                      String                 @id @default(cuid())
  flightDispatchId        String                 @unique
  flightDispatch          FlightDispatch         @relation(fields: [flightDispatchId], references: [id], onDelete: Cascade)
  status                  OfpStatus              @default(GENERATED)
  version                 Int                    @default(1)
  simbriefStaticId        String                 @unique
  simbriefUserId          String?
  ofpUrl                  String?
  pdfUrl                  String?
  ofpSnapshot             Json?
  fuelPolicyProfileId     String?
  fuelPolicyProfile       FuelPolicyProfile?     @relation(fields: [fuelPolicyProfileId], references: [id], onDelete: SetNull)
  fuelPolicySnapshot      Json?
  tankeringRecommendation Json?
  tankeringApplied        Boolean                @default(false)
  contentHash             String
  signedByPilotId         String?
  signedByName            String?
  signedByCallsign        String?
  signatureData           String?
  acceptanceText          String?
  signedAt                DateTime?
  voidedAt                DateTime?
  voidReason              String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  dispatchRelease         DispatchRelease?
  flightAnalysisReports   FlightAnalysisReport[]

  @@index([status, signedAt])
}

model FlightAnalysisReport {
  id                    String       @id @default(cuid())
  pirepId               String       @unique
  pirep                 Pirep        @relation(fields: [pirepId], references: [id], onDelete: Cascade)
  ofpBriefingId         String?
  ofpBriefing           OfpBriefing? @relation(fields: [ofpBriefingId], references: [id], onDelete: SetNull)
  plannedBlockMinutes   Int?
  actualBlockMinutes    Int?
  blockTimeDiffMinutes  Int?
  plannedFlightMinutes  Int?
  actualFlightMinutes   Int?
  flightTimeDiffMinutes Int?
  plannedTripFuelKg     Int?
  actualFuelUsedKg      Int?
  fuelDiffKg            Int?
  fuelDiffPercent       Float?
  plannedRoute          String?
  actualDistanceNm      Int?
  landingRate           Int?
  landingG              Float?
  summary               Json
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([ofpBriefingId])
  @@index([fuelDiffPercent])
}

model EfbPerformanceCalculation {
  id                       String   @id @default(cuid())
  pilotId                  String
  pilot                    Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  ofpBriefingId            String?
  flightDispatchId         String?
  vamsysBookingId          String?
  type                     String
  mode                     String   @default("MANUAL")
  airportIcao              String
  runway                   String?
  aircraftType             String
  aircraftRegistration     String?
  weightKg                 Int?
  source                   String   @default("simbrief_v2")
  input                    Json
  result                   Json?
  status                   String
  warningLevel             String?
  errorMessage             String?
  officialForDeparture     Boolean  @default(false)
  usedForReadyForDeparture Boolean  @default(false)
  createdAt                DateTime @default(now())

  @@index([pilotId, createdAt])
  @@index([ofpBriefingId])
  @@index([flightDispatchId])
  @@index([vamsysBookingId])
  @@index([type, airportIcao])
}

model EfbDepartureReadiness {
  id                   String    @id @default(cuid())
  flightDispatchId     String    @unique
  pilotId              String
  pilot                Pilot     @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  status               String    @default("PENDING")
  takeoffPerformanceId String?
  blockingReason       String?
  warnings             Json?
  readyAt              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([pilotId, status])
}

model FuelPolicyProfile {
  id                 String        @id @default(cuid())
  name               String
  scope              String
  aircraftCategory   String?
  routeType          String?
  region             String?
  contingencyRule    String
  finalReserveRule   String
  taxiFuelKg         Int?
  minFobKg           Int?
  minArrivalFuelKg   Int?
  atcFuelMinutes     Int?
  weatherFuelMinutes Int?
  melFuelKg          Int?
  extraFuelKg        Int?
  tankeringAllowed   Boolean       @default(false)
  active             Boolean       @default(true)
  ofpBriefings       OfpBriefing[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([active, routeType, region])
  @@index([aircraftCategory])
}

model DispatchRelease {
  id                       String      @id @default(cuid())
  ofpBriefingId            String      @unique
  ofpBriefing              OfpBriefing @relation(fields: [ofpBriefingId], references: [id], onDelete: Cascade)
  status                   String      @default("PENDING")
  riskLevel                String      @default("UNKNOWN")
  ofpCheckStatus           String      @default("PENDING")
  fuelCheckStatus          String      @default("PENDING")
  aircraftConditionStatus  String      @default("PENDING")
  takeoffPerformanceStatus String      @default("NOT_REQUIRED")
  landingPerformanceStatus String      @default("NOT_REQUIRED")
  weatherStatus            String      @default("UNKNOWN")
  alternateStatus          String      @default("UNKNOWN")
  etopsStatus              String      @default("NOT_REQUIRED")
  checks                   Json
  warnings                 Json?
  blockingItems            Json?
  releasedAt               DateTime?
  releasedByPilotId        String?
  releasedByStaffId        String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([status, riskLevel])
  @@index([releasedAt])
}

model PilotBooking {
  id                       String             @id @default(cuid())
  dataOrigin               AocDataOrigin      @default(HISPAFLY_NATIVE)
  pilotId                  String
  pilot                    Pilot              @relation(fields: [pilotId], references: [id], onDelete: Restrict)
  flightId                 String?
  flight                   Flight?            @relation(fields: [flightId], references: [id], onDelete: Restrict)
  routeId                  String?
  route                    Route?             @relation(fields: [routeId], references: [id], onDelete: Restrict)
  aircraftId               String?
  aircraft                 Aircraft?          @relation(fields: [aircraftId], references: [id], onDelete: SetNull)
  dispatch                 FlightDispatch?
  vamsysBookingId          String?            @unique
  vamsysRouteId            String?
  vamsysAircraftId         String?
  vamsysFleetId            String?
  departureIcao            String
  arrivalIcao              String
  flightNumber             String?
  callsign                 String?
  aircraftType             String?
  aircraftRegistration     String?
  selectedDepartureAt      DateTime
  estimatedArrivalAt       DateTime?
  estimatedDurationMinutes Int?
  network                  String?
  altitude                 Int?
  passengers               Int?
  cargoKg                  Int?
  userRoute                String?
  status                   PilotBookingStatus @default(BOOKED)
  matchedPirepId           String?            @unique
  matchedPirep             Pirep?             @relation(fields: [matchedPirepId], references: [id], onDelete: Restrict)
  cancelledAt              DateTime?
  errorMessage             String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@unique([pilotId, flightId])
  @@index([pilotId, status])
  @@index([flightId])
  @@index([routeId])
  @@index([aircraftId, selectedDepartureAt, estimatedArrivalAt])
  @@index([dataOrigin])
  @@index([selectedDepartureAt])
}

model PayrollRule {
  id             String          @id @default(cuid())
  name           String
  version        Int
  aircraftRates  Json
  bonusRules     Json?
  penaltyRules   Json?
  effectiveFrom  DateTime
  effectiveUntil DateTime?
  isActive       Boolean         @default(false)
  payrollRecords PayrollRecord[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([name, version])
  @@index([isActive, effectiveFrom])
}

model AocAuditLog {
  id          String     @id @default(cuid())
  staffUserId String?
  staffUser   StaffUser? @relation(fields: [staffUserId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  message     String     @default("")
  metadata    Json?      @map("details")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  @@index([staffUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}
